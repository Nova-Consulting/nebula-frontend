{
	"_version": "1.12.0",

	"sap.app": {
		"id": "br.com.novaconsulting.admin",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "${version}"
		},
		
		"dataSources": {
			"mainService": {
				"uri": "http://localhost:4004/odata/v4/admin/",
				"type": "OData",
				"settings": {
				"annotations": [],
				"localUri": "localService/metadata.xml",
				"odataVersion": "4.0"
				}
			}
		}
	},

	"sap.ui": {
		"technology": "UI5",
		"icons": {},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},


	"sap.ui5": {
		"rootView": {
			"viewName": "br.com.novaconsulting.admin.view.App",
			"type": "XML",
			"async": true,
			"id": "app"
		},
		"resources": {
			"css": [
			  {
				"uri": "css/style.css"
			  }
			]
		},
		"dependencies": {
			"minUI5Version": "1.122.1",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {},
				"sap.tnt": {},
				"sap.ui.webc.fiori": {},
				"sap.f": {},
				"sap.fiori": {},
				"sap.ui.layout": {},
				"sap.ui.unified": {},
				"sap.suite.ui.microchart": {}
			}
		},

		"handleValidation": true,

		"contentDensities": {
			"compact": true,
			"cozy": true
		},

		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "br.com.novaconsulting.admin.i18n.i18n"
				}
			}
		},

		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"type": "View",
				"viewType": "XML",
				"viewPath": "br.com.novaconsulting.admin.view",
				
				"controlId": "app",
				"controlAggregation": "pages",
				
				"clearTarget" : "true",
				"async": true,
				"bypassed": {
					"target": "notFound"
				}
			},
			"routes": [
				{
					"pattern": "",
					"name": "main",
					"target": "inicioTarget1"
				},
				{
					"pattern": "main",
					"name": "main1",
					"target": "mainTarget"
				},
				{
					"pattern": "master",
					"name": "master",
					"target": "masterTarget"
				},
				{
					"name": "inicioRoute1",
					"pattern": "inicio",
					"target": "inicioTarget1"
				},
				{
					"name": "loginRoute",
					"pattern": "login",
					"target": "loginTarget"
				},
				{
					"name": "recoverRoute",
					"pattern": "recover-password",
					"target": "recoverTarget"
				}
			],
			"targets": {
				"mainTarget": {
					"viewId": "main",
					"viewName": "Main",
					"level": 1
				},
				"masterTarget": {
					"path": "br.com.novaconsulting.admin.view",
					"name": "Master",
					"parent": "mainTarget",
					"controlId": "parentNavContainer",
					"clearAggregation": true,
					"transition": "slide",
					"level": 3
				},
				"inicioTarget1": {
					"path": "br.com.novaconsulting.admin.view",
					"name": "Inicio",
					"transition": "slide",
					"parent": "mainTarget",
					"controlId": "parentNavContainer",
					"level": 2
				},
				"loginTarget": {
					"path": "br.com.novaconsulting.admin.view",
					"name": "login",
					"level": 1
				},
				"recoverTarget": {
					"path": "br.com.novaconsulting.admin.view",
					"name": "recover",
					"level": 1
				},
				"notFound": {
					"path": "br.com.novaconsulting.admin.view",
					"name": "NotFound",
					"transition": "slide",
					"parent": "mainTarget",
					"controlId": "parentNavContainer",
					"level": 0
				}
			}
			
		}
	}
}
