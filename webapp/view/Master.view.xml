<mvc:View
	controllerName="br.com.novaconsulting.admin.controller.Master"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	xmlns:microchart="sap.suite.ui.microchart">
	<Page title="Dados Mestres">
		
		<layout:VerticalLayout class="sapUiResponsiveMargin">
			
			<layout:HorizontalLayout allowWrapping="true">
				<GenericTile
					class="sapUiTinyMarginBegin sapUiTinyMarginTop"
					header="{i18n>companyTitle}"
					press="onNavToProcessFlow">
					<tileContent>
						<TileContent>
							<content>
								<NumericContent
									scale="%"
									value="{
										path: 'process>/Nodes',
										formatter: '.getProgress'
									}"
									icon="sap-icon://factory" />
							</content>
						</TileContent>
					</tileContent>
				</GenericTile>
				<GenericTile
					class="sapUiTinyMarginBegin sapUiTinyMarginTop"
					header="{i18n>plantTitle}"
					press="onNavToProcessFlow">
					<tileContent>
						<TileContent>
							<content>
								<NumericContent
									scale="%"
									value="{
										path: 'process>/Nodes',
										formatter: '.getProgress'
									}"
									icon="sap-icon://factory" />
							</content>
						</TileContent>
					</tileContent>
				</GenericTile>
				<GenericTile
					class="sapUiTinyMarginBegin sapUiTinyMarginTop"
					header="{i18n>storageTitle}"
					press="onNavToProcessFlow">
					<tileContent>
						<TileContent>
							<content>
								<NumericContent
									scale="%"
									value="{
										path: 'process>/Nodes',
										formatter: '.getProgress'
									}"
									icon="sap-icon://factory" />
							</content>
						</TileContent>
					</tileContent>
				</GenericTile>
				
			</layout:HorizontalLayout>
			<layout:HorizontalLayout allowWrapping="true">
				<GenericTile
					class="sapUiTinyMarginBegin sapUiTinyMarginTop"
					header="Portarias"
					press="onNavToProcessFlow">
					<tileContent>
						<TileContent>
							<content>
								<NumericContent
									scale="%"
									value="{
										path: 'process>/Nodes',
										formatter: '.getProgress'
									}"
									icon="sap-icon://factory" />
							</content>
						</TileContent>
					</tileContent>
				</GenericTile>
				<GenericTile
					class="sapUiTinyMarginBegin sapUiTinyMarginTop"
					header="Processos"
					press="onNavToProcessFlow">
					<tileContent>
						<TileContent>
							<content>
								<NumericContent
									scale="%"
									value="{
										path: 'process>/Nodes',
										formatter: '.getProgress'
									}"
									icon="sap-icon://factory" />
							</content>
						</TileContent>
					</tileContent>
				</GenericTile>
				
				
			</layout:HorizontalLayout>
			<layout:HorizontalLayout allowWrapping="true">
				<GenericTile
					class="sapUiTinyMarginBegin sapUiTinyMarginTop"
					header="Veículos"
					press="onNavToProcessFlow">
					<tileContent>
						<TileContent>
							<content>
								<NumericContent
									scale="%"
									value="{
										path: 'process>/Nodes',
										formatter: '.getProgress'
									}"
									icon="sap-icon://factory" />
							</content>
						</TileContent>
					</tileContent>
				</GenericTile>
				<GenericTile
					class="sapUiTinyMarginBegin sapUiTinyMarginTop"
					header="Safra"
					press="onNavToProcessFlow">
					<tileContent>
						<TileContent>
							<content>
								<NumericContent
									scale="%"
									value="{
										path: 'process>/Nodes',
										formatter: '.getProgress'
									}"
									icon="sap-icon://factory" />
							</content>
						</TileContent>
					</tileContent>
				</GenericTile>
				<GenericTile
					class="sapUiTinyMarginBegin sapUiTinyMarginTop"
					header="Cultura"
					press="onNavToProcessFlow">
					<tileContent>
						<TileContent>
							<content>
								<NumericContent
									scale="%"
									value="{
										path: 'process>/Nodes',
										formatter: '.getProgress'
									}"
									icon="sap-icon://factory" />
							</content>
						</TileContent>
					</tileContent>
				</GenericTile>
				
			</layout:HorizontalLayout>
			
		</layout:VerticalLayout>

	</Page>
</mvc:View>

